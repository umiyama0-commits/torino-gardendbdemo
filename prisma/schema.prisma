generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id             String    @id @default(cuid())
  name           String
  industry       String    @default("")
  industryDetail String?
  scale          String?
  contractStatus String    @default("active")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  stores         Store[]
  projects       Project[]

  @@index([industry])
}

model Store {
  id           String        @id @default(cuid())
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  name         String
  locationType String
  area         Float?
  staffCount   Int?
  address      String?
  createdAt    DateTime      @default(now())
  spatialZones SpatialZone[]
  observations Observation[]
}

model SpatialZone {
  id       String @id @default(cuid())
  storeId  String
  store    Store  @relation(fields: [storeId], references: [id])
  name     String
  zoneType String
}

model Project {
  id               String        @id @default(cuid())
  clientId         String
  client           Client        @relation(fields: [clientId], references: [id])
  name             String
  hypothesisTheme  String?
  primaryValueAxis String?
  targetKPI        String?
  status           String        @default("active")
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime       @default(now())
  observations     Observation[]
  analysisTrees    AnalysisTree[]
}

model OntologyTag {
  id              String           @id @default(cuid())
  type            String
  level           Int              @default(1)
  code            String           @unique
  displayNameJa   String
  displayNameEn   String?
  description     String?
  modelLayer      String?
  category        String?
  parentId        String?
  parent          OntologyTag?     @relation("TagHierarchy", fields: [parentId], references: [id])
  children        OntologyTag[]    @relation("TagHierarchy")
  clientId        String?
  observationTags ObservationTag[]
  insightTags     InsightTag[]
}

model Observation {
  id               String                   @id @default(cuid())
  projectId        String?
  project          Project?                 @relation(fields: [projectId], references: [id])
  storeId          String?
  store            Store?                   @relation(fields: [storeId], references: [id])
  text             String
  summary          String?                  // 一覧表示用の短い要約（30〜50文字）
  subjectivity     String                   @default("objective")
  confidence       String                   @default("MEDIUM")
  modelLayer       String
  provenance       String                   @default("FIELD_OBSERVED")
  primaryValueAxis String?
  sourceType       String?
  sourceUrl        String?
  sourceTitle      String?
  similarityHint   String?
  country          String                   @default("JP") // ISO 3166-1 alpha-2
  trustScore       Float                    @default(0.5)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  tags             ObservationTag[]
  rawFiles         RawFile[]
  insightLinks     ObservationInsightLink[]

  @@index([provenance])
  @@index([modelLayer])
  @@index([primaryValueAxis])
  @@index([country])
  @@index([trustScore])
  @@index([createdAt])
  @@index([projectId])
  @@index([storeId])
}

model ObservationTag {
  id            String      @id @default(cuid())
  observationId String
  observation   Observation @relation(fields: [observationId], references: [id], onDelete: Cascade)
  tagId         String
  tag           OntologyTag @relation(fields: [tagId], references: [id])

  @@index([observationId])
  @@index([tagId])
}

model Insight {
  id                   String                    @id @default(cuid())
  text                 String
  evidenceStrength     String                    @default("MEDIUM")
  generalizability     String                    @default("MEDIUM")
  applicableConditions String?
  counterConditions    String?
  valueImpact          String?
  primaryValueAxis     String?
  modelLayer           String?
  provenance           String                    @default("FIELD_OBSERVED")
  derivedFromId        String?
  countries            String                    @default("JP") // カンマ区切り: "JP,US,KR"
  trustScore           Float                     @default(0.5)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  tags                 InsightTag[]
  clusterMemberships   SimilarityClusterMember[]
  sourceObservations   ObservationInsightLink[]
  patternLinks         PatternInsightLink[]

  @@index([provenance])
  @@index([trustScore])
  @@index([createdAt])
}

model InsightTag {
  id        String      @id @default(cuid())
  insightId String
  insight   Insight     @relation(fields: [insightId], references: [id], onDelete: Cascade)
  tagId     String
  tag       OntologyTag @relation(fields: [tagId], references: [id])

  @@index([insightId])
  @@index([tagId])
}

model CrossIndustryPattern {
  id               String               @id @default(cuid())
  name             String
  description      String
  industries       String
  countries        String               @default("JP") // カンマ区切り
  modelLayer       String?
  primaryValueAxis String?
  insightCount     Int                  @default(0)
  trustScore       Float                @default(0.5)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  insightLinks     PatternInsightLink[]

  @@index([trustScore])
}

// ─── 導出リレーション（パイプライン接続） ──────────────────────────
// Observation → Insight の多対多リンク（Stage 2→3 の昇格パス）

model ObservationInsightLink {
  id            String      @id @default(cuid())
  observationId String
  observation   Observation @relation(fields: [observationId], references: [id], onDelete: Cascade)
  insightId     String
  insight       Insight     @relation(fields: [insightId], references: [id], onDelete: Cascade)
  role          String      @default("supporting") // supporting, contradicting, example
  createdAt     DateTime    @default(now())

  @@unique([observationId, insightId])
  @@index([observationId])
  @@index([insightId])
}

// Insight → CrossIndustryPattern の多対多リンク（Stage 3 内の昇格パス）

model PatternInsightLink {
  id        String               @id @default(cuid())
  patternId String
  pattern   CrossIndustryPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
  insightId String
  insight   Insight              @relation(fields: [insightId], references: [id], onDelete: Cascade)
  createdAt DateTime             @default(now())

  @@unique([patternId, insightId])
  @@index([patternId])
  @@index([insightId])
}

// ─── コンパイルイベント（self-improving loop 記録） ─────────────────

model CompilationEvent {
  id                    String   @id @default(cuid())
  trigger               String   // ingest, qa_feedback, linting, manual
  sourceType            String?  // observation, insight, pattern, qa_session
  sourceId              String?
  resultType            String?  // observation, insight, pattern, lint_result
  resultId              String?
  llmModel              String?
  promptTokens          Int?
  completionTokens      Int?
  createdAt             DateTime @default(now())

  @@index([trigger])
  @@index([createdAt])
}

// ─── Linting 結果（Stage 6: 能動的品質向上） ───────────────────────

model LintResult {
  id          String   @id @default(cuid())
  type        String   // contradiction, gap, connection, topic_suggestion
  targetType  String   // observation, insight, pattern
  targetId    String
  relatedType String?  // observation, insight, pattern
  relatedId   String?
  description String
  severity    String   @default("info") // critical, warning, info
  status      String   @default("open") // open, resolved, dismissed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([targetType, targetId])
  @@index([status])
  @@index([createdAt])
}

model SimilarityCluster {
  id               String                    @id @default(cuid())
  name             String
  description      String?
  memberCount      Int                       @default(0)
  modelLayer       String?
  primaryValueAxis String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  members          SimilarityClusterMember[]
}

model SimilarityClusterMember {
  id        String            @id @default(cuid())
  clusterId String
  cluster   SimilarityCluster @relation(fields: [clusterId], references: [id])
  insightId String
  insight   Insight           @relation(fields: [insightId], references: [id])
  addedAt   DateTime          @default(now())
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  role          String         @default("consultant") // admin, consultant, viewer
  apiKey        String?        @unique
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  analysisTrees AnalysisTree[] @relation("TreeCreator")

  @@index([role])
}

// ─── システム設定（Master Config） ──────────────────────────
// 管理者のみ変更可能なグローバル設定

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String
  category  String   @default("general") // general, llm, trust, display
  updatedAt DateTime @updatedAt

  @@index([category])
}

// ─── Raw Files (生データファイル管理) ────────────────────────────
// コンパイラ・パイプラインの第1段: raw/ 取り込み
// 報告書PDF・日報テキスト・動画等のアップロードファイルを管理
// fileType values: PDF, DOCX, TXT, CSV, MP4, MOV, PNG, JPG, OTHER

model RawFile {
  id              String        @id @default(cuid())
  fileName        String
  fileType        String
  mimeType        String
  fileSize        Int
  blobUrl         String
  status          String        @default("uploaded") // uploaded, extracting, extracted, error
  extractedText   String?
  errorMessage    String?
  observationId   String?
  observation     Observation?  @relation(fields: [observationId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([observationId])
  @@index([createdAt])
}

// ─── Q&A セッション（Stage 4: self-improving loop） ──────────────

model QASession {
  id        String      @id @default(cuid())
  question  String
  answer    String
  reasoning String?
  // 回答に使用したObservation/InsightのID (JSON配列)
  referencedObservationIds String?
  referencedInsightIds     String?
  feedback  String?     // helpful, unhelpful, partial
  // フィードバック起因で生成されたInsightのID
  generatedInsightId String?
  createdAt DateTime    @default(now())

  @@index([feedback])
  @@index([createdAt])
}

// ─── Analysis Tree (PF分析ツリー構造) ───────────────────────────
// Tollino Gardenの標準コンサルフレームワーク
// CATEGORY → PERFORMANCE → INDICATOR → FACTOR → COUNTERMEASURE
// テンプレート（isTemplate=true）を雛形として、PJ毎にクローンして使用

// AnalysisNodeType values: CATEGORY, PERFORMANCE, INDICATOR, FACTOR, COUNTERMEASURE

model AnalysisTree {
  id          String         @id @default(cuid())
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  isTemplate  Boolean        @default(false)
  templateId  String?
  template    AnalysisTree?  @relation("TreeTemplate", fields: [templateId], references: [id])
  instances   AnalysisTree[] @relation("TreeTemplate")
  status      String         @default("draft")
  createdById String?
  createdBy   User?          @relation("TreeCreator", fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  nodes       AnalysisNode[]

  @@index([projectId])
  @@index([isTemplate])
  @@index([templateId])
}

model AnalysisNode {
  id                   String             @id @default(cuid())
  treeId               String
  tree                 AnalysisTree       @relation(fields: [treeId], references: [id], onDelete: Cascade)
  parentId             String?
  parent               AnalysisNode?      @relation("NodeHierarchy", fields: [parentId], references: [id])
  children             AnalysisNode[]     @relation("NodeHierarchy")
  templateNodeId       String?
  nodeType             String
  label                String
  description          String?
  sortOrder            Int                @default(0)
  linkedObservationIds String?
  outgoingLinks        AnalysisNodeLink[] @relation("LinkSource")
  incomingLinks        AnalysisNodeLink[] @relation("LinkTarget")
  metrics              AnalysisMetric[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([treeId])
  @@index([treeId, nodeType])
  @@index([parentId])
  @@index([templateNodeId])
}

model AnalysisMetric {
  id          String       @id @default(cuid())
  nodeId      String
  node        AnalysisNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  label       String
  unit        String?
  valueBefore String?
  valueAfter  String?
  colorBefore String?
  colorAfter  String?
  trend       String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([nodeId])
}

model AnalysisNodeLink {
  id           String       @id @default(cuid())
  sourceNodeId String
  sourceNode   AnalysisNode @relation("LinkSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNodeId String
  targetNode   AnalysisNode @relation("LinkTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  linkType     String       @default("addresses")
  note         String?
  createdAt    DateTime     @default(now())

  @@unique([sourceNodeId, targetNodeId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
}
